<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_employee_view_form_arca_ficha" model="ir.ui.view">
        <field name="name">hr.employee.view.form.arca.ficha</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button name="%(arca_ficha_wizard_action)d" type="action"
                        class="oe_stat_button" icon="fa-id-card-o"
                        context="{'default_employee_id': id}">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Ficha ARCA</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
